APP_HOST=0.0.0.0
APP_PORT=8081
APP_REPOSITORY_BACKEND=sqlite
APP_QUEUE_BACKEND=kafka
APP_SQLITE_PATH=.data/task-orchestrator.db
APP_QUEUE_POLL_INTERVAL_SECONDS=0.1
APP_POSTGRES_DSN=
APP_POSTGRES_SCHEMA=public
APP_REDIS_URL=redis://127.0.0.1:6379/0
APP_REDIS_STREAM_KEY=embedding:tasks
APP_REDIS_CONSUMER_GROUP=embedding-task-workers
APP_REDIS_CONSUMER_NAME=task-orchestrator-1
APP_REDIS_DEAD_LETTER_STREAM_KEY=embedding:tasks:dlq
APP_REDIS_BLOCK_MILLISECONDS=1000
APP_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
APP_KAFKA_TOPIC=embedding.tasks
APP_KAFKA_DEAD_LETTER_TOPIC=embedding.tasks.dlq
APP_KAFKA_GROUP_ID=embedding-task-workers
APP_KAFKA_CLIENT_ID=task-orchestrator
APP_KAFKA_POLL_TIMEOUT_MILLISECONDS=1000
APP_PREPROCESS_URL=http://127.0.0.1:8085
APP_RUNTIME_URL=http://127.0.0.1:8082
APP_VECTOR_STORE_URL=http://127.0.0.1:8083
APP_HTTP_TIMEOUT_SECONDS=5
APP_DEFAULT_INDEX_ID=default-index
APP_MAX_ATTEMPTS=3
APP_RETRY_BACKOFF_SECONDS=0.1
